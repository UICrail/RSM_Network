        <iri>
          <value>https://cdm.ovh/rsm/network/netw#ContainingEntity</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#ContainingEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Containing entity</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/network/netw#ContainingEntity</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>A NetEntity that may contain other net entities, to build an 'authoritative' breakdown of net entities. The way the breakdown is defined (by area first, or by subsystem first...) is left to the data owner.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
