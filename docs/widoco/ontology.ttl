@prefix : <https://cdm.ovh/rsm/network/netw#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://cdm.ovh/rsm/network/netw#> .

<https://cdm.ovh/rsm/network/netw> rdf:type owl:Ontology ;
                                    owl:versionIRI <https://cdm.ovh/rsm/network/netw/0.1> ;
                                    owl:imports <https://cdm.ovh/rsm/time/time> .

#################################################################
#    Object Properties
#################################################################

###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasMember
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasMember> rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart> rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant> rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasProperPart
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasProperPart> rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesTime
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesTime> rdf:type owl:ObjectProperty .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies
<http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> rdf:type owl:ObjectProperty .


###  https://cdm.ovh/rsm/network/netw#concernsNetwork
:concernsNetwork rdf:type owl:ObjectProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :NetworkManagement ;
                 rdfs:range :RailwayNetwork ;
                 rdfs:label "concerns network"@en .


###  https://cdm.ovh/rsm/network/netw#containsEntity
:containsEntity rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasProperPart> ,
                                   :containsEntityTransitive ;
                owl:inverseOf :isContainedIn ;
                rdf:type owl:IrreflexiveProperty ;
                rdfs:domain :ContainingEntity ;
                rdfs:range :NetEntity ;
                rdfs:comment "Refers to entities that are proper parts of the containing entity. 'Proper' entails that the property is irreflexive, and it is characterized as such in this version of the ontology. As container entities can contain other containers, use the transitive property closure to find all entities contained, directly or indirectly, in a container."@en ;
                rdfs:label "contains entity" .


###  https://cdm.ovh/rsm/network/netw#containsEntityTransitive
:containsEntityTransitive rdf:type owl:ObjectProperty ,
                                   owl:TransitiveProperty ;
                          rdfs:domain :ContainingEntity ;
                          rdfs:range :NetEntity ;
                          rdfs:comment "use for retrieving all entities contained, directly or indirectly, in a container"@en ;
                          rdfs:label "contains entity (transitive)" .


###  https://cdm.ovh/rsm/network/netw#definedByCollection
:definedByCollection rdf:type owl:ObjectProperty ;
                     rdfs:domain :SubNetwork ;
                     rdfs:range :NetEntityCollection ;
                     rdfs:label "defined by collection"@en .


###  https://cdm.ovh/rsm/network/netw#hasInfrastructureManager
:hasInfrastructureManager rdf:type owl:ObjectProperty ,
                                   owl:FunctionalProperty ;
                          rdfs:domain :NetworkManagement ;
                          rdfs:range :InfrastructureManager ;
                          rdfs:label "has Infrastructure Manager"@en .


###  https://cdm.ovh/rsm/network/netw#hasSelectionCriterion
:hasSelectionCriterion rdf:type owl:ObjectProperty ;
                       rdfs:domain :NetEntityCollection ;
                       rdfs:range :SelectionCriterion ;
                       rdfs:label "has selection criterion"@en .


###  https://cdm.ovh/rsm/network/netw#hasSubNetwork
:hasSubNetwork rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart> ;
               owl:inverseOf :isSubNetworkOf ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :ContainingEntity
                                           :SubNetwork
                                         )
                           ] ;
               rdfs:range :SubNetwork ;
               rdfs:comment "Links an infrastructure artefact (network or sub-network) to its sub-networks."@en ;
               rdfs:label "has sub network"@en .


###  https://cdm.ovh/rsm/network/netw#hasTopology
:hasTopology rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies> ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :NetworkLayout ;
             rdfs:range :NetworkTopology ;
             rdfs:label "has topology"@en .


###  https://cdm.ovh/rsm/network/netw#involvesNetwork
:involvesNetwork rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant> ;
                 rdfs:domain :NetworkLayout ;
                 rdfs:range :RailwayNetwork ;
                 rdfs:label "involvesNetwork" .


###  https://cdm.ovh/rsm/network/netw#isContainedIn
:isContainedIn rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :isContainedInTransitive ;
               rdfs:label "is contained in"@en .


###  https://cdm.ovh/rsm/network/netw#isContainedInTransitive
:isContainedInTransitive rdf:type owl:ObjectProperty ,
                                  owl:TransitiveProperty ;
                         rdfs:label "is contained in (transitive)" .


###  https://cdm.ovh/rsm/network/netw#isSubNetworkOf
:isSubNetworkOf rdf:type owl:ObjectProperty ;
                rdfs:label "is subnetwork of" .


###  https://cdm.ovh/rsm/network/netw#selectedFromNetwork
:selectedFromNetwork rdf:type owl:ObjectProperty ;
                     rdfs:domain :NetEntityCollection ;
                     rdfs:range [ rdf:type owl:Class ;
                                  owl:unionOf ( :ContainingEntity
                                                :SubNetwork
                                              )
                                ] ;
                     rdfs:label "selected from network"@en .


###  https://cdm.ovh/rsm/network/netw#serializedAs
:serializedAs rdf:type owl:ObjectProperty ;
              rdfs:domain :NetworkTopology ;
              rdfs:range :TopologyGraph ;
              rdfs:label "serialized as"@en .


###  https://cdm.ovh/rsm/time/time#hasValidityInterval
<https://cdm.ovh/rsm/time/time#hasValidityInterval> rdf:type owl:ObjectProperty ;
                                                    rdfs:subPropertyOf <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesTime> ;
                                                    rdf:type owl:FunctionalProperty ,
                                                             owl:InverseFunctionalProperty ;
                                                    rdfs:range <http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval> ;
                                                    rdfs:label "has validity interval"@en .


