        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Collection"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasMember"/>
                <owl:allValuesFrom rdf:resource="https://cdm.ovh/rsm/network/netw#NetEntity"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A collection of net entities, typically selected from one or more railway networks, and possibly used to define a sub-network. Collection membership (using dul:hasMember) is user-defined, and has no formal relationship with netw:containsEntity.</rdfs:comment>
        <rdfs:label>Net Entity collection</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/network/netw#NetworkLayout -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/network/netw#NetworkLayout">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#Situation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/network/netw#hasTopology"/>
                <owl:someValuesFrom rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkTopology"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://cdm.ovh/rsm/time/time#hasValidityInterval"/>
                <owl:allValuesFrom rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Associates a Railway Network with a topology. Validity interval, if provided, bounds the validity of this association.</rdfs:comment>
        <rdfs:label>Network layout</rdfs:label>
    </owl:Class>
    


