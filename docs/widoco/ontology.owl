<?xml version="1.0"?>
<rdf:RDF xmlns="https://cdm.ovh/rsm/network/netw#"
     xml:base="https://cdm.ovh/rsm/network/netw"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="https://cdm.ovh/rsm/network/netw">
        <owl:versionIRI rdf:resource="https://cdm.ovh/rsm/network/netw/0.1"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/time/time"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasMember -->


    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasMember"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart -->


    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant -->


    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasProperPart -->


    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasProperPart"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesTime -->


    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesTime"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies -->


    <owl:ObjectProperty rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies"/>
    


    <!-- https://cdm.ovh/rsm/network/netw#concernsNetwork -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#concernsNetwork">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkManagement"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#RailwayNetwork"/>
        <rdfs:label xml:lang="en">concerns network</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#containsEntity -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#containsEntity">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasProperPart"/>
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/network/netw#containsEntityTransitive"/>
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/network/netw#isContainedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#ContainingEntity"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#NetEntity"/>
        <rdfs:comment xml:lang="en">Refers to entities that are proper parts of the containing entity. &apos;Proper&apos; entails that the property is irreflexive, and it is characterized as such in this version of the ontology. As container entities can contain other containers, use the transitive property closure to find all entities contained, directly or indirectly, in a container.</rdfs:comment>
        <rdfs:label>contains entity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#containsEntityTransitive -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#containsEntityTransitive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#ContainingEntity"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#NetEntity"/>
        <rdfs:comment xml:lang="en">use for retrieving all entities contained, directly or indirectly, in a container</rdfs:comment>
        <rdfs:label>contains entity (transitive)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#definedByCollection -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#definedByCollection">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#SubNetwork"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#NetEntityCollection"/>
        <rdfs:label xml:lang="en">defined by collection</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#hasInfrastructureManager -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#hasInfrastructureManager">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkManagement"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#InfrastructureManager"/>
        <rdfs:label xml:lang="en">has Infrastructure Manager</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#hasSelectionCriterion -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#hasSelectionCriterion">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetEntityCollection"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#SelectionCriterion"/>
        <rdfs:label xml:lang="en">has selection criterion</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#hasSubNetwork -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#hasSubNetwork">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasPart"/>
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/network/netw#isSubNetworkOf"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/network/netw#ContainingEntity"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/network/netw#SubNetwork"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#SubNetwork"/>
        <rdfs:comment xml:lang="en">Links an infrastructure artefact (network or sub-network) to its sub-networks.</rdfs:comment>
        <rdfs:label xml:lang="en">has sub network</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#hasTopology -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#hasTopology">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#satisfies"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkLayout"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkTopology"/>
        <rdfs:label xml:lang="en">has topology</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#involvesNetwork -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#involvesNetwork">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasParticipant"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkLayout"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#RailwayNetwork"/>
        <rdfs:label>involvesNetwork</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isContainedIn -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isContainedIn">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/network/netw#isContainedInTransitive"/>
        <rdfs:label xml:lang="en">is contained in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isContainedInTransitive -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isContainedInTransitive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:label>is contained in (transitive)</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#isSubNetworkOf -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#isSubNetworkOf">
        <rdfs:label>is subnetwork of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#selectedFromNetwork -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#selectedFromNetwork">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetEntityCollection"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/network/netw#ContainingEntity"/>
                    <rdf:Description rdf:about="https://cdm.ovh/rsm/network/netw#SubNetwork"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:label xml:lang="en">selected from network</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/network/netw#serializedAs -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/network/netw#serializedAs">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/network/netw#NetworkTopology"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/network/netw#TopologyGraph"/>
        <rdfs:label xml:lang="en">serialized as</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/time/time#hasValidityInterval -->


    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/time/time#hasValidityInterval">
        <rdfs:subPropertyOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#includesTime"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#TimeInterval"/>
        <rdfs:label xml:lang="en">has validity interval</rdfs:label>
    </owl:ObjectProperty>
    


