    "@language" : "en",
    "@value" : "such as 'High speed...', 'TEN-T', 'Latvian National wide gauge'. Characterization is left open to extensions as SKOS concept schemes or subclasses."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Net entity selection criterion"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
