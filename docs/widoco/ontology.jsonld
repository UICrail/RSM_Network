  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Associates a Railway Network with a topology. Validity interval, if provided, bounds the validity of this association."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Network layout"
  } ],
