    "@id" : "https://cdm.ovh/rsm/network/netw#RailwayNetwork"
  } ]
}, {
  "@id" : "https://cdm.ovh/rsm/network/netw#containsEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Refers to entities that are proper parts of the containing entity. 'Proper' entails that the property is irreflexive, and it is characterized as such in this version of the ontology. As container entities can contain other containers, use the transitive property closure to find all entities contained, directly or indirectly, in a container."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://cdm.ovh/rsm/network/netw#ContainingEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "contains entity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://cdm.ovh/rsm/network/netw#NetEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.ontologydesignpatterns.org/ont/dul/DUL.owl#hasProperPart"
  }, {
    "@id" : "https://cdm.ovh/rsm/network/netw#containsEntityTransitive"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://cdm.ovh/rsm/network/netw#isContainedIn"
  } ]
}, {
  "@id" : "https://cdm.ovh/rsm/network/netw#containsEntityTransitive",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#TransitiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "use for retrieving all entities contained, directly or indirectly, in a container"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://cdm.ovh/rsm/network/netw#ContainingEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "contains entity (transitive)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://cdm.ovh/rsm/network/netw#NetEntity"
  } ]
}, {
