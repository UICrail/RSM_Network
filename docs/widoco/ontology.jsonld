  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A Topology Graph individual denotes an information object carrying a serialized graph, typically retrievable from a file such as <http://example.org/topology1.ttl>. There can be several files, e.g. to provide several formats such as TTL, RDFXML, or JSON-LD."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
